<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<layout name="PNH_MapSelectionMenu">
    <Window pos="0 0 1 1" align="center" valign="center" background="0 0 0 0.8" blur="10">
        <Widget name="PNH_RootPanel" pos="0 0 1 1" align="center" valign="center" background="0 0 0 0.7">
            <Border color="0.1 0.1 0.1 0.8" size="2"/>
            <Padding padding="10"/>

            <Panel name="PNH_HeaderPanel" pos="0 0 1 0.08" align="top" background="0.1 0.1 0.1 0.9">
                <TextWidget name="PNH_OperatorName" pos="0.02 0 0.4 1" align="left" valign="center" text="OPERADOR: ---" font="DayZDefault_Medium" size="20"/>
                <TextWidget name="PNH_ATMBalance" pos="0.02 0 0.4 1" align="right" valign="center" text="SALDO: ---" font="DayZDefault_Medium" size="20" color="0 1 0 1"/>
            </Panel>

            <GridSpacerWidget name="PNH_MapGridSpacer" pos="0.02 0.1 0.3 0.8" align="left" content_halign="center"/>

            <Panel name="PNH_DetailsPanel" pos="0.35 0.1 0.63 0.8" align="left" background="0.1 0.1 0.1 0.8">
                <ImageWidget name="PNH_MapImage" pos="0 0 1 0.5" align="top" scaleToContent="1"/>
                <TextWidget name="PNH_MapTitle" pos="0 0.52 1 0.08" align="top" text="SELECIONE UM MAPA" font="DayZDefault_Bold" size="28"/>
                <RichTextWidget name="PNH_MapStats" pos="0 0.62 1 0.15" align="top" font="DayZDefault_Medium" size="18"/>
                <RichTextWidget name="PNH_MapDescription" pos="0 0.78 1 0.1" align="top" font="DayZDefault_Light" size="16"/>
                <ButtonWidget name="PNH_ActionButton" pos="0 0.9 1 0.1" align="bottom" text="INGRESSAR" font="DayZDefault_Bold"/>
            </Panel>

            <ButtonWidget name="PNH_CloseButton" pos="0.95 0.01 0.04 0.04" align="right" text="X" color="1 0 0 1"/>
        </Widget>
    </Window>
</layout>